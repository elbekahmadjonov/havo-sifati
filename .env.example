# Telegram ogohlantirish sozlamalari (ixtiyoriy)
# BotFather orqali bot yarating va token oling: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# AQI chegara — shu qiymatdan oshsa Telegram xabari yuboriladi
AQI_CHEGARA=150

# Server porti (standart: 8000)
PORT=8000
